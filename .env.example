# Database
DATABASE_URL=

# Redis
REDIS_URL=

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# HMAC (for QR tokens)
HMAC_SECRET=

# WhatsApp (Evolution API)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=

# AI / OCR
GOOGLE_VISION_API_KEY=
ANTHROPIC_API_KEY=
OCR_CONFIDENCE_THRESHOLD=0.7

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Resend)
RESEND_API_KEY=

# Geofencing
GEO_MAX_SPEED_KMH=200

# Reconciliation
RECONCILIATION_WINDOW_HOURS=24

# Offline queue
OFFLINE_QUEUE_TTL_HOURS=24

# Invoice validation
INVOICE_AMOUNT_TOLERANCE=0.05

# Redemption QR TTL
REDEMPTION_TOKEN_TTL_MINUTES=15

# Welcome bonus
WELCOME_BONUS_AMOUNT=50

# Attribution
ATTRIBUTION_WINDOW_HOURS=48

# WhatsApp OTP template (Meta). When set, first-time users can receive the OTP
# without first messaging the business. Register in Meta Business Manager,
# category "Authentication".
META_WHATSAPP_OTP_TEMPLATE=
META_WHATSAPP_OTP_TEMPLATE_LANG=es

# Meta App Secret — used to verify the X-Hub-Signature-256 HMAC on every
# incoming webhook. Find it in Meta Developer Console → App → Settings →
# Basic → App Secret. When set, the webhook rejects any POST whose signature
# doesn't match. Leave empty in dev to skip verification (logs a warning).
META_APP_SECRET=

# Sentry (observability). Leave DSN empty to disable — SDK becomes a no-op.
# Get a DSN at sentry.io → create project → Node + Next.js.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_DSN=

# Database backups (hourly cron in scripts/backup/backup-db.sh)
BACKUP_DIR=/var/backups/valee
RETENTION_DAYS=7
BACKUP_S3_BUCKET=

# WhatsApp merchant-scan attribution window (minutes). When a consumer scans
# a merchant QR, the next invoice image they send within this window is
# credited to that merchant. Default 4h covers the "scan at arrival, send
# invoice 3h later" pattern at restaurants / events.
MERCHANT_SCAN_WINDOW_MIN=240
STAFF_ATTRIBUTION_WINDOW_MIN=60

# Server
PORT=3000
HOST=0.0.0.0
EXCHANGE_RATE_FETCH_TIMES=
PASSWORD_RESET_TTL_MINUTES=30
