generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum TenantStatus {
  active
  inactive
}

enum AccountType {
  shadow
  verified
  system
}

enum SystemAccountType {
  issued_value_pool
  redemption_holding
}

enum LedgerEventType {
  INVOICE_CLAIMED
  REDEMPTION_PENDING
  REDEMPTION_CONFIRMED
  REDEMPTION_EXPIRED
  REVERSAL
  ADJUSTMENT_MANUAL
  TRANSFER_P2P
  PRESENCE_VALIDATED
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

enum LedgerReferenceType {
  invoice
  redemption_token
  manual_adjustment
  transfer
  system
}

enum LedgerStatus {
  confirmed
  provisional
  reversed
}

enum InvoiceStatus {
  available
  claimed
  pending_validation
  rejected
  manual_review
}

enum InvoiceSource {
  csv_upload
  photo_submission
  mobile_payment
  voucher
  dual_scan
  pos_webhook
  fudo_webhook
}

enum UploadBatchStatus {
  queued
  processing
  completed
  failed
}

enum RedemptionTokenStatus {
  pending
  used
  expired
}

enum StaffRole {
  owner
  cashier
}

enum AuditActorType {
  staff
  admin
}

enum AuditActorRole {
  owner
  cashier
  admin
}

enum AuditActionType {
  QR_SCAN_SUCCESS
  QR_SCAN_FAILURE
  IDENTITY_UPGRADE
  CUSTOMER_LOOKUP
  CSV_UPLOAD
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_TOGGLED
  STAFF_CREATED
  STAFF_DEACTIVATED
  STAFF_BRANCH_CHANGED
  MANUAL_ADJUSTMENT
  DISPUTE_APPROVED
  DISPUTE_REJECTED
  DISPUTE_ESCALATED
  TENANT_CREATED
  TENANT_DEACTIVATED
  BRANCH_CREATED
  BRANCH_TOGGLED
  BRANCH_QR_GENERATED
  STAFF_QR_GENERATED
  SESSION_TERMINATED
}

enum AuditOutcome {
  success
  failure
}

enum DisputeStatus {
  open
  approved
  rejected
  escalated
}

enum DisputeResolverType {
  staff
  admin
}

enum ExchangeSource {
  bcv
  binance_p2p
  bybit_p2p
  promedio
  euro_bcv
}

enum ReferenceCurrency {
  usd
  eur
  bs
}

enum PlanTier {
  basic
  pro
  x10
}

enum TrustLevel {
  level_1_strict
  level_2_standard
  level_3_presence
}

// ============================================================
// 1. TENANTS
// ============================================================

model Tenant {
  id         String       @id @default(uuid()) @db.Uuid
  name       String       @db.VarChar(255)
  slug       String       @unique @db.VarChar(100)
  status     TenantStatus @default(active)
  ownerEmail       String       @map("owner_email") @db.VarChar(255)
  qrCodeUrl        String?      @map("qr_code_url")
  logoUrl          String?      @map("logo_url")
  address          String?      @db.VarChar(500)
  contactPhone     String?      @map("contact_phone") @db.VarChar(30)
  contactEmail     String?      @map("contact_email") @db.VarChar(255)
  website          String?      @db.VarChar(500)
  description      String?      @db.VarChar(1000)
  instagramHandle  String?      @map("instagram_handle") @db.VarChar(100)
  /// Default 5000 (Eric 2026-04-25). Was 50 — too small to feel meaningful
  /// for first-time merchants. The onboarding shows it formatted as "5.000".
  welcomeBonusAmount Int        @default(5000) @map("welcome_bonus_amount")
  /// When false, no welcome bonus is issued AND the bot stops mentioning it.
  /// Eric 2026-04-25: setting amount to 0 used to leak "te regalo 0 puntos" to
  /// the consumer; this is the clean ON/OFF the merchant pauses with.
  welcomeBonusActive Boolean    @default(true) @map("welcome_bonus_active")
  /// Optional cap on number of welcome bonuses issued per tenant. Once reached,
  /// new consumers do not receive the bonus and the bot does not mention it.
  /// Null = no cap.
  welcomeBonusLimit  Int?       @map("welcome_bonus_limit")
  /// Default 1000 (Eric 2026-04-25). Was 100.
  referralBonusAmount Int       @default(1000) @map("referral_bonus_amount")
  referralBonusActive Boolean   @default(true) @map("referral_bonus_active")
  referralBonusLimit  Int?      @map("referral_bonus_limit")
  rif              String?      @db.VarChar(50)
  preferredExchangeSource ExchangeSource? @map("preferred_exchange_source")
  referenceCurrency       ReferenceCurrency @default(usd) @map("reference_currency")
  dualScanCapPerCashier   Int      @default(50) @map("dual_scan_cap_per_cashier")
  dualScanCapPerConsumer  Int      @default(5)  @map("dual_scan_cap_per_consumer")
  dualScanTtlSeconds      Int      @default(60) @map("dual_scan_ttl_seconds")
  /// When true, a consumer can redeem a QR generated at one branch from any
  /// other branch of the same tenant (Genesis H11). When false the cashier's
  /// branch must match the branch that was selected when the redemption was
  /// initiated. Default true — consumers expect "points are per merchant".
  crossBranchRedemption   Boolean  @default(true) @map("cross_branch_redemption")
  plan                    PlanTier @default(basic)
  trustLevel              TrustLevel @default(level_2_standard) @map("trust_level")
  redemptionFeePercent       Decimal? @map("redemption_fee_percent") @db.Decimal(5, 2)
  attributedSaleFeePercent   Decimal? @map("attributed_sale_fee_percent") @db.Decimal(5, 2)
  attributedCustomerFixedFee Decimal? @map("attributed_customer_fixed_fee") @db.Decimal(10, 2)
  posWebhookSecret           String?  @map("pos_webhook_secret")
  fudoApiKey                 String?  @map("fudo_api_key")
  fudoWebhookSecret          String?  @map("fudo_webhook_secret")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  branches          Branch[]
  accounts          Account[]
  ledgerEntries     LedgerEntry[]
  invoices          Invoice[]
  uploadBatches     UploadBatch[]
  products          Product[]
  staff             Staff[]
  auditLogs         AuditLog[]
  disputes          Dispute[]
  tenantAssetConfig TenantAssetConfig[]
  redemptionTokens  RedemptionToken[]
  idempotencyKeys   IdempotencyKey[]
  otpSessions            OtpSession[]
  recurrenceRules        RecurrenceRule[]
  recurrenceNotifications RecurrenceNotification[]
  dualScanSessions       DualScanSession[]

  @@map("tenants")
}

// ============================================================
// 2. BRANCHES
// ============================================================

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(255)
  address   String?
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  qrCodeUrl String?  @map("qr_code_url")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  ledgerEntries    LedgerEntry[]
  invoices         Invoice[]
  redemptionTokens RedemptionToken[]
  staff            Staff[]
  products         Product[]
  productAssignments ProductBranch[]
  dualScanSessions DualScanSession[]

  @@index([tenantId])
  @@index([tenantId, active])
  @@map("branches")
}

// ============================================================
// 3. ASSET_TYPES (global)
// ============================================================

model AssetType {
  id                    String  @id @default(uuid()) @db.Uuid
  name                  String  @unique @db.VarChar(100)
  unitLabel             String  @map("unit_label") @db.VarChar(50)
  defaultConversionRate Decimal @map("default_conversion_rate") @db.Decimal(18, 8)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenantAssetConfigs TenantAssetConfig[]
  ledgerEntries      LedgerEntry[]
  products           Product[]
  redemptionTokens   RedemptionToken[]
  dualScanSessions   DualScanSession[]

  @@map("asset_types")
}

// ============================================================
// 4. TENANT_ASSET_CONFIG
// ============================================================

model TenantAssetConfig {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  assetTypeId    String   @map("asset_type_id") @db.Uuid
  conversionRate Decimal  @map("conversion_rate") @db.Decimal(18, 8)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  assetType AssetType @relation(fields: [assetTypeId], references: [id])

  @@unique([tenantId, assetTypeId])
  @@map("tenant_asset_config")
}

// ============================================================
// 5. ACCOUNTS
// ============================================================

model Account {
  id                String             @id @default(uuid()) @db.Uuid
  tenantId          String             @map("tenant_id") @db.Uuid
  phoneNumber       String?            @map("phone_number") @db.VarChar(30)
  displayName       String?            @map("display_name") @db.VarChar(100)
  cedula            String?            @db.VarChar(20)
  accountType          AccountType        @map("account_type")
  systemAccountType    SystemAccountType? @map("system_account_type")
  level                Int                @default(1)
  welcomeBonusGranted  Boolean            @default(false) @map("welcome_bonus_granted")
  referralSlug         String?            @unique @map("referral_slug") @db.VarChar(16)
  tokensInvalidatedAt  DateTime?          @map("tokens_invalidated_at") @db.Timestamptz
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  ledgerEntries    LedgerEntry[]
  invoices         Invoice[]
  redemptionTokens        RedemptionToken[]
  auditLogs               AuditLog[]
  disputes                Dispute[]
  recurrenceNotifications RecurrenceNotification[]
  referralsGiven          Referral[]    @relation("Referrer")
  referralsReceived       Referral[]    @relation("Referee")

  @@unique([tenantId, phoneNumber])
  @@unique([tenantId, cedula])
  @@unique([tenantId, systemAccountType])
  @@index([tenantId, accountType])
  @@map("accounts")
}

// Consumer-to-consumer referrals. A referrer's personal QR links to a
// merchant with a `Ref2U:<slug>` marker. When a new consumer scans it and
// completes their first validated transaction at that merchant, the referrer
// earns the tenant-configured bonus (or a platform default).
enum ReferralStatus {
  pending
  credited
  rejected
}

model Referral {
  id                String          @id @default(uuid()) @db.Uuid
  tenantId          String          @map("tenant_id") @db.Uuid
  referrerAccountId String          @map("referrer_account_id") @db.Uuid
  refereeAccountId  String          @map("referee_account_id") @db.Uuid
  originStaffId     String?         @map("origin_staff_id") @db.Uuid
  status            ReferralStatus  @default(pending)
  bonusAmount       Decimal?        @map("bonus_amount") @db.Decimal(18, 8)
  bonusLedgerId     String?         @map("bonus_ledger_id") @db.Uuid
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz
  creditedAt        DateTime?       @map("credited_at") @db.Timestamptz

  referrer    Account @relation("Referrer", fields: [referrerAccountId], references: [id])
  referee     Account @relation("Referee",  fields: [refereeAccountId],  references: [id])
  originStaff Staff?  @relation(fields: [originStaffId], references: [id])

  @@unique([tenantId, refereeAccountId]) // one referral slot per referee per tenant
  @@index([tenantId, referrerAccountId])
  @@index([tenantId, originStaffId, status])
  @@index([status, createdAt])
  @@map("referrals")
}

// ============================================================
// 6. LEDGER_ENTRIES (APPEND-ONLY, IMMUTABLE)
// ============================================================

model LedgerEntry {
  id            String              @id @default(uuid()) @db.Uuid
  tenantId      String              @map("tenant_id") @db.Uuid
  eventType     LedgerEventType     @map("event_type")
  entryType     LedgerEntryType     @map("entry_type")
  accountId     String              @map("account_id") @db.Uuid
  pairedEntryId String?             @map("paired_entry_id") @db.Uuid // FK managed in custom SQL (DEFERRABLE INITIALLY DEFERRED)
  amount        Decimal             @db.Decimal(18, 8)
  assetTypeId   String              @map("asset_type_id") @db.Uuid
  referenceId   String              @map("reference_id") @db.VarChar(255)
  referenceType LedgerReferenceType @map("reference_type")
  branchId      String?             @map("branch_id") @db.Uuid
  latitude      Decimal?            @db.Decimal(10, 7)
  longitude     Decimal?            @db.Decimal(10, 7)
  deviceId      String?             @map("device_id") @db.VarChar(255)
  status        LedgerStatus        @default(confirmed)
  prevHash      String?             @map("prev_hash") @db.VarChar(64)
  hash          String              @db.VarChar(64)
  metadata      Json?
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  account   Account   @relation(fields: [accountId], references: [id])
  assetType AssetType @relation(fields: [assetTypeId], references: [id])
  branch    Branch?   @relation(fields: [branchId], references: [id])

  // pairedEntry relation removed — FK is DEFERRABLE INITIALLY DEFERRED (custom SQL)
  // Use pairedEntryId field directly for queries

  invoices                Invoice[]
  redemptionTokens        RedemptionToken[]
  disputes                Dispute[]
  recurrenceNotifications RecurrenceNotification[]

  @@unique([tenantId, referenceId, entryType])
  @@index([tenantId, accountId])
  @@index([tenantId, eventType])
  @@index([tenantId, referenceId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@map("ledger_entries")
}

// ============================================================
// 7. INVOICES
// ============================================================

model Invoice {
  id                 String        @id @default(uuid()) @db.Uuid
  tenantId           String        @map("tenant_id") @db.Uuid
  branchId           String?       @map("branch_id") @db.Uuid
  invoiceNumber      String        @map("invoice_number") @db.VarChar(255)
  amount             Decimal       @db.Decimal(18, 2)
  transactionDate    DateTime?     @map("transaction_date") @db.Timestamptz
  customerPhone      String?       @map("customer_phone") @db.VarChar(30)
  status             InvoiceStatus @default(available)
  source             InvoiceSource
  uploadBatchId      String?       @map("upload_batch_id") @db.Uuid
  consumerAccountId  String?       @map("consumer_account_id") @db.Uuid
  ledgerEntryId      String?       @map("ledger_entry_id") @db.Uuid
  ocrRawText         String?       @map("ocr_raw_text")
  extractedData      Json?         @map("extracted_data")
  orderDetails       Json?         @map("order_details")
  confidenceScore    Decimal?      @map("confidence_score") @db.Decimal(4, 3)
  submittedLatitude  Decimal?      @map("submitted_latitude") @db.Decimal(10, 7)
  submittedLongitude Decimal?      @map("submitted_longitude") @db.Decimal(10, 7)
  rejectionReason    String?       @map("rejection_reason")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  branch          Branch?      @relation(fields: [branchId], references: [id])
  uploadBatch     UploadBatch? @relation(fields: [uploadBatchId], references: [id])
  consumerAccount Account?     @relation(fields: [consumerAccountId], references: [id])
  ledgerEntry     LedgerEntry? @relation(fields: [ledgerEntryId], references: [id])

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, status])
  @@index([tenantId, customerPhone])
  @@index([tenantId, uploadBatchId])
  @@map("invoices")
}

// ============================================================
// 8. UPLOAD_BATCHES
// ============================================================

model UploadBatch {
  id               String            @id @default(uuid()) @db.Uuid
  tenantId         String            @map("tenant_id") @db.Uuid
  filename         String            @db.VarChar(255)
  fileUrl          String?           @map("file_url")
  status           UploadBatchStatus @default(queued)
  rowsLoaded       Int?              @map("rows_loaded")
  rowsSkipped      Int?              @map("rows_skipped")
  rowsErrored      Int?              @map("rows_errored")
  errorDetails     Json?             @map("error_details")
  uploadedByStaffId String           @map("uploaded_by_staff_id") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz
  completedAt      DateTime?         @map("completed_at") @db.Timestamptz

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  staff     Staff     @relation(fields: [uploadedByStaffId], references: [id])
  invoices  Invoice[]

  @@map("upload_batches")
}

// ============================================================
// 9. REDEMPTION_TOKENS
// ============================================================

model RedemptionToken {
  id                   String                @id @default(uuid()) @db.Uuid
  tenantId             String                @map("tenant_id") @db.Uuid
  consumerAccountId    String                @map("consumer_account_id") @db.Uuid
  productId            String                @map("product_id") @db.Uuid
  amount               Decimal               @db.Decimal(18, 8)
  cashAmount           Decimal?              @map("cash_amount") @db.Decimal(18, 2)
  assetTypeId          String                @map("asset_type_id") @db.Uuid
  status               RedemptionTokenStatus @default(pending)
  tokenSignature       String                @map("token_signature") @db.VarChar(64)
  shortCode            String?               @map("short_code") @db.VarChar(6)
  expiresAt            DateTime              @map("expires_at") @db.Timestamptz
  usedAt               DateTime?             @map("used_at") @db.Timestamptz
  usedByStaffId        String?               @map("used_by_staff_id") @db.Uuid
  branchId             String?               @map("branch_id") @db.Uuid
  ledgerPendingEntryId String                @map("ledger_pending_entry_id") @db.Uuid
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz

  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  consumerAccount Account     @relation(fields: [consumerAccountId], references: [id])
  product         Product     @relation(fields: [productId], references: [id])
  assetType       AssetType   @relation(fields: [assetTypeId], references: [id])
  usedByStaff     Staff?      @relation("RedemptionUsedBy", fields: [usedByStaffId], references: [id])
  branch          Branch?     @relation(fields: [branchId], references: [id])
  ledgerEntry     LedgerEntry @relation(fields: [ledgerPendingEntryId], references: [id])

  @@index([tenantId, status])
  @@index([consumerAccountId])
  @@index([tokenSignature])
  @@index([tenantId, shortCode])
  @@map("redemption_tokens")
}

// ============================================================
// 10. PRODUCTS
// ============================================================

model Product {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  branchId            String?   @map("branch_id") @db.Uuid
  name                String    @db.VarChar(255)
  description         String?
  photoUrl            String?   @map("photo_url")
  redemptionCost      Decimal   @map("redemption_cost") @db.Decimal(18, 8)
  cashPrice           Decimal?  @map("cash_price") @db.Decimal(18, 2)
  assetTypeId         String    @map("asset_type_id") @db.Uuid
  stock               Int       @default(0)
  minLevel            Int       @default(1) @map("min_level")
  active              Boolean   @default(true)
  archivedAt          DateTime? @map("archived_at") @db.Timestamptz
  identityEditCount   Int       @default(0) @map("identity_edit_count")
  stockAutoDisabled   Boolean   @default(false) @map("stock_auto_disabled")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  branch           Branch?           @relation(fields: [branchId], references: [id])
  assetType        AssetType         @relation(fields: [assetTypeId], references: [id])
  redemptionTokens RedemptionToken[]
  branchAssignments ProductBranch[]

  @@index([tenantId, active])
  @@index([tenantId, active, stock])
  @@index([tenantId, archivedAt])
  @@index([tenantId, branchId, active])
  @@map("products")
}

// Join table for the multi-sucursal scope of a product. Eric 2026-04-26: a
// merchant must be able to flag "Doritos esta en Valencia y Caracas pero no
// en Maracay" — the legacy Product.branchId column only allowed a single
// sucursal or "Todas las sucursales", with no in-between. Empty assignment
// set === tenant-wide (visible/redeemable everywhere). The legacy
// Product.branchId is kept as a "primary" hint and mirrors the first
// assignment, so any code that still reads it keeps working.
model ProductBranch {
  productId String   @map("product_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([productId, branchId])
  @@index([branchId])
  @@map("product_branches")
}

// ============================================================
// 11. STAFF
// ============================================================

model DualScanSession {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  branchId    String?  @map("branch_id") @db.Uuid
  cashierId   String   @map("cashier_id") @db.Uuid
  amount      Decimal  @db.Decimal(18, 8)
  assetTypeId String   @map("asset_type_id") @db.Uuid
  nonce       String   @unique @db.VarChar(32)
  status      String   @default("pending") @db.VarChar(16)
  expiresAt   DateTime @map("expires_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  branch    Branch?   @relation(fields: [branchId], references: [id])
  cashier   Staff     @relation(fields: [cashierId], references: [id])
  assetType AssetType @relation(fields: [assetTypeId], references: [id])

  @@index([tenantId, cashierId, createdAt(sort: Desc)])
  @@index([status, expiresAt])
  @@map("dual_scan_sessions")
}

model Staff {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  branchId       String?   @map("branch_id") @db.Uuid
  name           String    @db.VarChar(255)
  email          String    @db.VarChar(255)
  passwordHash   String    @map("password_hash") @db.VarChar(255)
  role           StaffRole
  active         Boolean   @default(true)
  qrSlug         String?   @unique @map("qr_slug") @db.VarChar(16)
  qrCodeUrl      String?   @map("qr_code_url") @db.Text
  qrGeneratedAt  DateTime? @map("qr_generated_at") @db.Timestamptz
  tokensInvalidatedAt DateTime? @map("tokens_invalidated_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  branch         Branch?             @relation(fields: [branchId], references: [id])
  uploadBatches  UploadBatch[]
  redemptions    RedemptionToken[]   @relation("RedemptionUsedBy")
  scanSessions   StaffScanSession[]
  passwordResetTokens PasswordResetToken[]
  originReferrals Referral[]
  dualScanSessions DualScanSession[]

  @@unique([tenantId, email])
  @@map("staff")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  staffId   String    @map("staff_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(128)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  staff     Staff     @relation(fields: [staffId], references: [id])

  @@index([tokenHash])
  @@index([staffId])
  @@map("password_reset_tokens")
}

// Tracks which staff a consumer's last QR scan attributed to. Used by the
// invoice validation pipeline to credit the correct cashier/promoter for
// a transaction that lands within the attribution window.
model StaffScanSession {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  staffId      String   @map("staff_id") @db.Uuid
  consumerPhone String  @map("consumer_phone") @db.VarChar(32)
  scannedAt    DateTime @default(now()) @map("scanned_at") @db.Timestamptz

  staff  Staff  @relation(fields: [staffId], references: [id])

  @@index([tenantId, consumerPhone, scannedAt])
  @@map("staff_scan_sessions")
}

// Tracks the last merchant QR a consumer scanned. The webhook consults this
// when an image-only message arrives so the invoice gets attributed to the
// tenant the consumer actually intended, not whichever tenant their phone had
// recent ledger activity in.
model MerchantScanSession {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  branchId      String?  @map("branch_id") @db.Uuid
  consumerPhone String   @map("consumer_phone") @db.VarChar(32)
  scannedAt     DateTime @default(now()) @map("scanned_at") @db.Timestamptz

  @@index([consumerPhone, scannedAt])
  @@map("merchant_scan_sessions")
}

// ============================================================
// 12. ADMIN_USERS
// ============================================================

model AdminUser {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("admin_users")
}

// ============================================================
// 13. AUDIT_LOG (APPEND-ONLY, IMMUTABLE)
// ============================================================

model AuditLog {
  id                String          @id @default(uuid()) @db.Uuid
  tenantId          String?         @map("tenant_id") @db.Uuid
  actorId           String          @map("actor_id") @db.Uuid
  actorType         AuditActorType  @map("actor_type")
  actorRole         AuditActorRole  @map("actor_role")
  actionType        AuditActionType @map("action_type")
  consumerAccountId String?         @map("consumer_account_id") @db.Uuid
  amount            Decimal?        @db.Decimal(18, 8)
  outcome           AuditOutcome
  failureReason     String?         @map("failure_reason")
  metadata          Json?
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz

  tenant          Tenant?  @relation(fields: [tenantId], references: [id])
  consumerAccount Account? @relation(fields: [consumerAccountId], references: [id])

  @@map("audit_log")
}

// ============================================================
// 14. DISPUTES
// ============================================================

model Dispute {
  id                       String              @id @default(uuid()) @db.Uuid
  tenantId                 String              @map("tenant_id") @db.Uuid
  consumerAccountId        String              @map("consumer_account_id") @db.Uuid
  description              String
  screenshotUrl            String?             @map("screenshot_url")
  status                   DisputeStatus       @default(open)
  resolverId               String?             @map("resolver_id") @db.Uuid
  resolverType             DisputeResolverType? @map("resolver_type")
  resolutionReason         String?             @map("resolution_reason")
  ledgerAdjustmentEntryId  String?             @map("ledger_adjustment_entry_id") @db.Uuid
  createdAt                DateTime            @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt               DateTime?           @map("resolved_at") @db.Timestamptz

  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  consumerAccount Account      @relation(fields: [consumerAccountId], references: [id])
  ledgerEntry     LedgerEntry? @relation(fields: [ledgerAdjustmentEntryId], references: [id])

  @@index([tenantId, status])
  @@index([consumerAccountId])
  @@map("disputes")
}

// ============================================================
// 15. IDEMPOTENCY_KEYS
// ============================================================

model IdempotencyKey {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String?  @map("tenant_id") @db.Uuid
  key          String   @unique @db.VarChar(255)
  resourceType String   @map("resource_type") @db.VarChar(100)
  result       Json
  expiresAt    DateTime @map("expires_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([expiresAt])
  @@map("idempotency_keys")
}

// ============================================================
// 16. OTP_SESSIONS
// ============================================================

model OtpSession {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid
  phoneNumber String   @map("phone_number") @db.VarChar(30)
  otpHash     String   @map("otp_hash") @db.VarChar(255)
  expiresAt   DateTime @map("expires_at") @db.Timestamptz
  used        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([phoneNumber, used, expiresAt])
  @@map("otp_sessions")
}

// ============================================================
// 17. RECURRENCE_RULES
// ============================================================

model RecurrenceRule {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String    @db.VarChar(255)
  intervalDays    Int       @map("interval_days")
  graceDays       Int       @default(1) @map("grace_days")
  messageTemplate String    @map("message_template")
  bonusAmount     Decimal?  @map("bonus_amount") @db.Decimal(18, 8)
  active          Boolean   @default(true)
  // If non-empty, only customers whose phone is in this list receive the message.
  // Empty/null means all lapsed customers (default behavior).
  targetPhones    String[]  @default([]) @map("target_phones")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  notifications RecurrenceNotification[]

  @@index([tenantId, active])
  @@map("recurrence_rules")
}

// ============================================================
// 18. RECURRENCE_NOTIFICATIONS
// ============================================================

model RecurrenceNotification {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  ruleId             String   @map("rule_id") @db.Uuid
  consumerAccountId  String   @map("consumer_account_id") @db.Uuid
  lastVisitAt        DateTime @map("last_visit_at") @db.Timestamptz
  daysSinceVisit     Int      @map("days_since_visit")
  messageSent        String   @map("message_sent")
  bonusGranted       Boolean  @default(false) @map("bonus_granted")
  ledgerEntryId      String?  @map("ledger_entry_id") @db.Uuid
  sentAt             DateTime @default(now()) @map("sent_at") @db.Timestamptz

  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  rule            RecurrenceRule @relation(fields: [ruleId], references: [id])
  consumerAccount Account        @relation(fields: [consumerAccountId], references: [id])
  ledgerEntry     LedgerEntry?   @relation(fields: [ledgerEntryId], references: [id])

  @@unique([tenantId, ruleId, consumerAccountId, lastVisitAt])
  @@index([tenantId, consumerAccountId])
  @@index([tenantId, sentAt])
  @@map("recurrence_notifications")
}

// ============================================================
// 19. EXCHANGE RATES (Venezuela multi-rate handling)
// ============================================================

model ExchangeRate {
  id         String            @id @default(uuid()) @db.Uuid
  source     ExchangeSource
  currency   ReferenceCurrency
  rateBs     Decimal           @map("rate_bs") @db.Decimal(18, 4)
  fetchedAt  DateTime          @default(now()) @map("fetched_at") @db.Timestamptz
  reportedAt DateTime          @map("reported_at") @db.Timestamptz

  @@index([source, currency, fetchedAt(sort: Desc)])
  @@map("exchange_rates")
}

// ============================================================
// 20. PLATFORM REVENUE (Valee monetization)
// ============================================================

enum RevenueSource {
  redemption_fee
  attributed_sale_fee
  attributed_customer_fee
}

model PlatformRevenue {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId     String        @map("tenant_id") @db.Uuid
  source        RevenueSource
  amount        Decimal       @db.Decimal(18, 8)
  currency      ReferenceCurrency
  baseAmount    Decimal?      @map("base_amount") @db.Decimal(18, 8)
  feePercent    Decimal?      @map("fee_percent") @db.Decimal(5, 2)
  ledgerEntryId String?       @map("ledger_entry_id") @db.Uuid
  metadata      Json?
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, source])
  @@map("platform_revenue")
}

// Single-row global config the admin can flip at runtime. First use case
// (Eric 2026-05-04): auth_channel = "whatsapp" | "sms" to switch the
// consumer OTP delivery between WhatsApp and Twilio Verify SMS.
model SystemSetting {
  key       String   @id @db.VarChar(64)
  value     Json
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy String?  @map("updated_by") @db.Uuid

  @@map("system_settings")
}
